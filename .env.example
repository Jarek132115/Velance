# ─── Frontend (Vite) — prefix with VITE_ to expose to browser ───────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── API server (Express — never expose to browser) ──────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ─── Server config ────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Notes ───────────────────────────────────────────────────────────────────
# Get Stripe keys: https://dashboard.stripe.com/apikeys
# Use pk_test_ / sk_test_ for development, pk_live_ / sk_live_ for production
# Stripe test card: 4242 4242 4242 4242, any future date, any CVC
#
# Get Supabase keys: https://supabase.com/dashboard/project/_/settings/api
# The anon key is safe to expose to browser — service key is NOT
#
# Supplier integrations:
# SelfNamed (white-label formulation): https://www.selfnamed.com
# Supliful (dropshipping supplements): https://www.supliful.com
